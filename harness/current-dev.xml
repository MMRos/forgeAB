<?xml version="1.0" encoding="UTF-8"?>
<!--
  current-dev.xml
  Archivo activo de desarrollo gestionado por el agente Leader.
  Estados válidos: Waiting | In Progress | Testing Pending | Completed
  Al completarse, cada función se mueve a story-dev.xml.
-->
<project>
  <meta>
    <name><!-- Nombre del proyecto --></name>
    <language><!-- Lenguaje(s) principal(es) --></language>
    <loop_mode><!-- true | false --></loop_mode>
    <created><!-- ISO 8601 --></created>
    <updated><!-- ISO 8601 --></updated>
  </meta>

  <functions>

    <!-- PLANTILLA — copiar y rellenar para cada función -->
    <function id="F001">
      <name><!-- nombre_explicativo_de_la_funcion --></name>
      <priority><!-- 1 = más alta --></priority>
      <status>Waiting</status>

      <specifications>
        <description><!-- Qué hace esta función --></description>
        <inputs>
          <input name="" type="" required="true" description=""/>
        </inputs>
        <outputs>
          <output name="" type="" description=""/>
        </outputs>
        <constraints>
          <!-- Límites, reglas de negocio, condiciones de borde -->
        </constraints>
        <assumptions>
          <!-- Asunciones del Specifier aprobadas por el usuario -->
        </assumptions>
      </specifications>

      <dependencies>
        <!-- IDs de funciones que deben completarse antes -->
      </dependencies>

      <skills_required>
        <!-- Nombres de skills pertinentes que cada subagente debe revisar -->
      </skills_required>

      <implementation>
        <!-- Rellena el Implementer: módulo, archivo, clase, línea de inicio -->
        <module></module>
        <file></file>
        <notes></notes>
      </implementation>

      <tests>
        <!-- Rellena el Trapper; el Tester marca cada resultado -->
        <test type="unit"        id="T001-U" status="Pending" result=""/>
        <test type="functional"  id="T001-F" status="Pending" result=""/>
        <test type="security"    id="T001-S" status="Pending" result=""/>
        <test type="integration" id="T001-I" status="Pending" result=""/>
      </tests>

      <error_log>
        <!-- Entradas automáticas del try-catch del Implementer -->
      </error_log>

      <timestamps>
        <started></started>
        <testing_started></testing_started>
        <completed></completed>
      </timestamps>
    </function>

  </functions>
</project>
