<?xml version="1.0" encoding="UTF-8"?>
<!--
  error-log.xml
  Registro de errores gestionado por el Tester.
  El Tester añade entradas; nunca elimina ni edita entradas existentes.
  El Leader y el Planner pueden consultarlo para detectar patrones estructurales.
-->
<error_log>
  <meta>
    <project><!-- Nombre del proyecto --></project>
    <language><!-- Lenguaje(s) --></language>
  </meta>

  <errors>

    <!-- PLANTILLA — copiar y rellenar para cada error -->
    <error id="E001">

      <function_id><!-- ID de la función en current-dev.xml --></function_id>
      <function_name><!-- Nombre de la función --></function_name>
      <test_id><!-- ID de la prueba que lo detectó --></test_id>
      <test_type><!-- unit | functional | security | integration --></test_type>

      <datetime><!-- ISO 8601: 2024-01-01T12:00:00Z --></datetime>

      <cause>
        <!-- Qué originó el error: lógica incorrecta, asunción inválida,
             dependencia fallida, condición de borde no contemplada, etc. -->
      </cause>

      <effect>
        <!-- Qué comportamiento incorrecto produce: excepción lanzada,
             dato corrupto, respuesta errónea, fallo silencioso, etc. -->
      </effect>

      <context>
        <!-- En qué circunstancias ocurre: entorno, estado del sistema,
             datos de entrada exactos, secuencia de llamadas previa -->
        <environment><!-- dev | test | staging | prod --></environment>
        <input_data><!-- Datos exactos que reproducen el error --></input_data>
        <system_state><!-- Estado relevante del sistema en el momento del fallo --></system_state>
        <stack_trace><!-- Stack trace completo si está disponible --></stack_trace>
      </context>

      <structural_impact>
        <!-- ¿Este error implica cambios en la arquitectura o diagramas?
             none | requires_diagram_update | requires_spec_change -->
        none
      </structural_impact>

      <resolution>
        <status><!-- open | in_progress | resolved --></status>
        <solution_applied>
          <!-- Descripción de la solución: qué se cambió y por qué.
               Dejar vacío si status = open o in_progress. -->
        </solution_applied>
        <resolved_at><!-- ISO 8601 o vacío --></resolved_at>
        <resolved_by><!-- Nombre del agente que aplicó la solución --></resolved_by>
      </resolution>

    </error>

  </errors>

</error_log>
